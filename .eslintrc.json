{
  "root": true,
  "env": {
    "node": true,
    "es2022": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "commonjs"
  },
  "overrides": [
    {
      "files": ["visualizador/js/**/*.js"],
      "env": {
        "browser": true,
        "node": false,
        "es2022": true
      },
      "parserOptions": {
        "ecmaVersion": 2022,
        "sourceType": "module"
      },
      "rules": {
        "no-constant-condition": ["error", { "checkLoops": false }],
        "no-unused-vars": ["error", { "args": "none", "varsIgnorePattern": "^_" }]
      }
    },
    {
      "files": ["**/*.test.js"],
      "env": {
        "jest": true,
        "node": true
      }
    }
  ]
}
